---
permalink: /search.json
---
[
  {% assign first = true %}
  {% for post in site.posts %}
    {% unless first %},{% endunless %}
    {% capture post_meta %}{{ post.categories | join: ', ' }} | {{ post.tags | join: ', ' }}{% endcapture %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "kind": "Post",
      "meta": {{ post_meta | strip | jsonify }},
      "excerpt": {{ post.excerpt | strip_html | strip_newlines | jsonify }}
    }
    {% assign first = false %}
  {% endfor %}
  {% for p in site.pages %}
    {% if p.title and p.url != '/search.json' %}
      {% unless first %},{% endunless %}
      {
        "title": {{ p.title | jsonify }},
        "url": {{ p.url | relative_url | jsonify }},
        "kind": "Page",
        "meta": {{ p.description | default: p.title | jsonify }},
        "excerpt": {{ p.content | strip_html | strip_newlines | jsonify }}
      }
      {% assign first = false %}
    {% endif %}
  {% endfor %}
]
